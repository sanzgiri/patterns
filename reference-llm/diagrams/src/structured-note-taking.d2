## Structured note-taking — externalized agentic memory
direction: down

agent: {
  label: "Agent"
  shape: hexagon
  style.fill: "#dbeafe"
  style.stroke: "#2563eb"
}

ctx: {
  label: "Context window\n(small, transient)"
  shape: rectangle
  style.fill: "#dcfce7"
  style.stroke: "#16a34a"
}

notes: {
  label: "External notes\n(persistent, unbounded)"
  shape: cylinder
  style.fill: "#fde68a"
  style.stroke: "#d97706"

  todo: {label: "TODO.md\n• in-progress work\n• checklist"; shape: page; style.fill: "#fef3c7"}
  state: {label: "STATE.json\n• decisions made\n• constraints"; shape: page; style.fill: "#fef3c7"}
  notes_md: {label: "NOTES.md\n• discovered facts\n• failure modes"; shape: page; style.fill: "#fef3c7"}
  workspace: {label: "workspace/\n• artifacts in progress\n• partial outputs"; shape: page; style.fill: "#fef3c7"}
}

read: {
  label: "read_notes\n(grep / glob / read_file)"
  shape: rectangle
  style.fill: "#f3e8ff"
  style.stroke: "#7c3aed"
}

write: {
  label: "write_notes\n(append, edit, structured update)"
  shape: rectangle
  style.fill: "#f3e8ff"
  style.stroke: "#7c3aed"
}

agent -> ctx: "lives in"
agent -> read: "pulls relevant notes\non demand"
agent -> write: "captures decisions\nas they happen"
read -> notes
write -> notes
notes -> ctx: "lightweight refs only\n(file paths, IDs)" {style.stroke: "#16a34a"; style.bold: true}
