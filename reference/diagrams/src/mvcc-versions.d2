# MVCC: each row has multiple versions, each tagged with txn id
direction: down

Row42: "ROW: id=42" {
  style: { fill: "#f5f5f5"; stroke: "#424242"; stroke-width: 2; border-radius: 8 }

  V1: "version 1\nname='Alice', age=30\ntxn_min=100 (CREATED by txn 100)\ntxn_max=150 (SUPERSEDED by txn 150)" { style: { fill: "#ffcdd2"; stroke: "#b71c1c" } }
  V2: "version 2\nname='Alice', age=31\ntxn_min=150\ntxn_max=200" { style: { fill: "#fff4c2"; stroke: "#bf360c" } }
  V3: "version 3\nname='Alice B.', age=31\ntxn_min=200\ntxn_max=null (CURRENT)" { style: { fill: "#c8e6c9"; stroke: "#1b5e20" } }

  V1 -> V2 -> V3
}

T100: "Reader txn at snapshot=170" {
  shape: rectangle
  style: { fill: "#bbdefb"; stroke: "#0d47a1"; border-radius: 8 }
  Q: "Visibility rule:\nrow visible if txn_min \u2264 my_snapshot < txn_max\n\n\u2022 V1: 100 \u2264 170 < 150 \u2192 NO (170 \u2265 150)\n\u2022 V2: 150 \u2264 170 < 200 \u2192 YES \u2190 reader sees this\n\u2022 V3: 200 \u2264 170 \u2192 NO (not yet created)"
}

T201: "Reader txn at snapshot=220" {
  shape: rectangle
  style: { fill: "#bbdefb"; stroke: "#0d47a1"; border-radius: 8 }
  Q2: "\u2022 V1: too old\n\u2022 V2: superseded by 200 \u2264 220\n\u2022 V3: 200 \u2264 220 < null \u2192 YES \u2190 reader sees this"
}

GC: "Garbage collection / vacuum:\nonce no active txn has snapshot < V1.txn_max=150,\nV1 can be safely removed.\n\nThis is what Postgres VACUUM, MVCC compaction\nin Cockroach/Spanner, and 'old version cleanup'\nin every MVCC engine actually do." {
  shape: rectangle
  style: { fill: "#e1bee7"; stroke: "#4a148c"; border-radius: 8 }
}

Row42 -> T100
Row42 -> T201
Row42 -> GC
